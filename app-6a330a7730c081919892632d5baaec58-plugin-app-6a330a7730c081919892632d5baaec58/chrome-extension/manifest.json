{
  "manifest_version": 3,
  "name": "Molded Recorder",
  "version": "0.1.0",
  "description": "Capture a product workflow as an rrweb session for Molded.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {"default_title": "Molded Recorder", "default_popup": "popup.html"},
  "background": {"service_worker": "background.js", "type": "module"}
}
